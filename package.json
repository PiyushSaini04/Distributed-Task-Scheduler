{
  "name": "task-scheduler",
  "version": "1.0.0",
  "description": "Distributed fault-tolerant background job processing system",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/api/server.js",
    "start:worker": "node dist/workers/worker.js",
    "start:reaper": "node dist/reaper/reaper.js",
    "start:scheduler": "node dist/queue/scheduler.js",
    "dev:api": "ts-node src/api/server.ts",
    "dev:worker": "ts-node src/workers/worker.ts",
    "dev:reaper": "ts-node src/reaper/reaper.ts",
    "dev:scheduler": "ts-node src/queue/scheduler.ts",
    "migrate": "ts-node src/database/migrate.ts",
    "lint": "eslint src tests --ext .ts",
    "lint:fix": "eslint src tests --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "jest",
    "test:unit": "jest --testPathPattern=tests/unit",
    "test:integration": "jest --testPathPattern=tests/integration --runInBand",
    "prepare": "husky install || true"
  },
  "keywords": ["task-scheduler", "queue", "redis", "distributed"],
  "license": "MIT",
  "dependencies": {
    "express": "^4.21.2",
    "ioredis": "^5.4.2",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3",
    "uuid": "^11.0.5",
    "winston": "^3.17.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.5",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.19.1",
    "@typescript-eslint/parser": "^8.19.1",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "prettier": "^3.4.2",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "node": ">=20"
  }
}
